<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme for TV -->
    <style name="Theme.BaiduTVPlayer" parent="Theme.Leanback">
        <item name="colorPrimary">#212121</item>
        <item name="colorPrimaryDark">#121212</item>
        <item name="colorAccent">#FF4081</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowActionBar">false</item>
    </style>

    <!-- Full screen theme for activities -->
    <style name="Theme.BaiduTVPlayer.FullScreen" parent="Theme.BaiduTVPlayer">
        <item name="android:windowBackground">@color/black</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowActionBar">false</item>
    </style>

    <!-- Button styles for focus state -->
    <style name="FocusableButtonStyle">
        <item name="android:background">@drawable/selector_item_background</item>
        <item name="android:padding">8dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>

</resources>